{
  "name": "@bgd-labs/rpc-env",
  "version": "2.4.3",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "echo 'No tests yet'",
    "format": "biome check --write",
    "prepublishOnly": "npm run build"
  },
  "author": "Jonas Strassel <jonas@bdglabs.com>",
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@bgd-labs/toolbox": "^0.2.25",
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "lefthook": "^2.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "tsup": {
    "entry": [
      "src/action.ts"
    ],
    "splitting": false,
    "sourcemap": false,
    "clean": true,
    "dts": true,
    "treeshake": true,
    "format": [
      "esm",
      "cjs"
    ]
  }
}
